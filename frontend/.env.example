# Local dev: Vite dev server proxies /api to this URL (see vite.config.ts).
VITE_API_URL=http://localhost:8000

# Production (Vercel / Netlify / etc.): NEVER use localhost — set in the host's
# Environment Variables UI to your public API, e.g.:
# VITE_API_URL=https://your-service-name.onrender.com
# Then redeploy so the value is baked into the build.
