# Backend configuration
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage paths (relative to backend/)
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
REPORT_DIR=./data/reports

# Upload limits
MAX_UPLOAD_BYTES=524288000   # 500 MB

# CV pipeline
YOLO_MODEL=yolov8n.pt
FRAME_SKIP=2
RESIZE_MAX=640
CONF_THRESHOLD=0.35
TRACK_BUFFER=30
FRAME_STREAM_EVERY=5         # push 1 of every N processed frames over WS

# File retention (hours)
FILE_RETENTION_HOURS=24
